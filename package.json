{
  "name": "hydrowise",
  "private": true,
  "packageManager": "bun@1.3.8",
  "workspaces": [
    "app/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@hydrowise/web",
    "dev:desktop": "turbo dev --filter=@hydrowise/desktop",
    "build": "turbo build",
    "build:desktop": "turbo build --filter=@hydrowise/desktop",
    "build:packages": "turbo build --filter=./packages/*",
    "build:apps": "turbo build --filter=./app/*",
    "clean": "turbo clean",
    "clean:build": "turbo clean && turbo build",
    "nuke": "turbo clean && rm -f bun.lock && rm -rf node_modules && find . -name 'node_modules' -type d -prune -exec rm -rf {} +",
    "preview": "turbo preview --filter=@hydrowise/web",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "check": "biome check . --write"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "turbo": "^2.8.1",
    "typescript": "~5.9.3"
  },
  "patchedDependencies": {
    "@huggingface/transformers@4.0.0-next.7": "patches/@huggingface%2Ftransformers@4.0.0-next.7.patch"
  }
}
