{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HydroWise",
  "version": "0.1.0",
  "identifier": "com.hydrowise.desktop",
  "build": {
    "beforeDevCommand": "bun run dev:frontend",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "HydroWise",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "headers": {
        "Cross-Origin-Opener-Policy": "same-origin",
        "Cross-Origin-Embedder-Policy": "require-corp"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"],
    "externalBin": ["binaries/llama-server"],
    "resources": ["resources/bge-small-en-v1.5-q4_k_m.gguf"]
  }
}
