{
  "name": "@hydrowise/ai-runtime",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "clean": "rm -rf dist",
    "check": "tsc --noEmit",
    "smoke:chat": "VITE_HYDROWISE_AI_RUNTIME=web bun run src/dev/chat-smoke.ts",
    "smoke:chat:stream": "VITE_HYDROWISE_AI_RUNTIME=web bun run src/dev/chat-stream-smoke.ts",
    "smoke:chat:desktop": "VITE_HYDROWISE_AI_RUNTIME=desktop bun run src/dev/chat-smoke-desktop.ts",
    "smoke:chat:stream:desktop": "VITE_HYDROWISE_AI_RUNTIME=desktop bun run src/dev/chat-stream-smoke-desktop.ts"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "2.0.35",
    "@ai-sdk/provider": "^3.0.8",
    "@huggingface/transformers": "^4.0.0-next.6",
    "ai": "^6.0.116"
  },
  "peerDependencies": {
    "ai": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vite-plugin-dts": "^4.5.4"
  }
}
