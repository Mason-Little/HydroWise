{
  "name": "@hydrowise/db",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./queries": "./src/queries/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "build": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun scripts/migrate.ts",
    "db:seed": "bun scripts/seed.ts",
    "db:studio": "bun scripts/studio.ts",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "check": "biome check ."
  },
  "dependencies": {
    "@hydrowise/entities": "workspace:*",
    "@electric-sql/pglite": "^0.3.7",
    "drizzle-orm": "^0.45.1"
  },
  "devDependencies": {
    "@electric-sql/pglite-socket": "^0.0.21",
    "@types/node": "^24.10.1",
    "drizzle-kit": "^0.31.1",
    "typescript": "~5.9.3"
  }
}
