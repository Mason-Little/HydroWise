                                        10
                                      ],
                                      "children": [
                                        {
                                          "type": "text",
                                          "id": "z3IyD",
                                          "fill": "#7A6A58",
                                          "content": "D. Linked genes are examples of independent assortment.",
                                          "fontFamily": "Inter",
                                          "fontSize": 11,
                                          "fontWeight": "normal"
                                        }
                                      ]
                                    }
                                  ]
                                },
                                {
                                  "type": "text",
                                  "id": "f0wOp",
                                  "fill": "#1f2328",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "Q2. Short response: In 1-2 sentences, explain how crossing over can make linked genes appear to assort independently.",
