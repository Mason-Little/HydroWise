                              "children": [
                                {
                                  "type": "text",
                                  "id": "Es9Zu",
                                  "fill": "#1f2328",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "Q1. Which statement best describes independent assortment?",
                                  "fontFamily": "Inter",
                                  "fontSize": 12,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "frame",
                                  "id": "6YGbf",
                                  "width": "fill_container",
                                  "layout": "vertical",
                                  "gap": 6,
                                  "children": [
                                    {
                                      "type": "frame",
                                      "id": "7BeXX",
                                      "fill": "#F8F2E8",
                                      "cornerRadius": 8,
                                      "stroke": {
                                        "thickness": 1,
                                        "fill": "#DED7CC"
                                      },
                                      "padding": [
                                        8,
                                        10
                                      ],
                                      "children": [
                                        {
                                          "type": "text",
                                          "id": "vIHfN",
                                          "fill": "#5C4B2F",
                                          "content": "A. Genes on different chromosomes separate independently during gamete formation.",
                                          "fontFamily": "Inter",
                                          "fontSize": 11,
                                          "fontWeight": "normal"
                                        }
                                      ]
                                    },
                                    {
                                      "type": "frame",
                                      "id": "j4903",
                                      "fill": "#FFFDF8",
                                      "cornerRadius": 8,
                                      "stroke": {
                                        "thickness": 1,
                                        "fill": "#DED7CC"
                                      },
                                      "padding": [
                                        8,
                                        10
                                      ],
                                      "children": [
                                        {
                                          "type": "text",
                                          "id": "c18rN",
                                          "fill": "#7A6A58",
                                          "content": "B. Genes always stay together and never recombine.",
                                          "fontFamily": "Inter",
                                          "fontSize": 11,
                                          "fontWeight": "normal"
                                        }
                                      ]
                                    },
                                    {
                                      "type": "frame",
                                      "id": "NJ4no",
                                      "fill": "#FFFDF8",
                                      "cornerRadius": 8,
                                      "stroke": {
                                        "thickness": 1,
                                        "fill": "#DED7CC"
                                      },
                                      "padding": [
                                        8,
                                        10
                                      ],
                                      "children": [
                                        {
                                          "type": "text",
                                          "id": "vi7my",
                                          "fill": "#7A6A58",
                                          "content": "C. Dominant alleles always assort before recessive alleles.",
                                          "fontFamily": "Inter",
                                          "fontSize": 11,
                                          "fontWeight": "normal"
                                        }
                                      ]
                                    },
                                    {
                                      "type": "frame",
                                      "id": "jGPuo",
                                      "fill": "#FFFDF8",
                                      "cornerRadius": 8,
                                      "stroke": {
                                        "thickness": 1,
